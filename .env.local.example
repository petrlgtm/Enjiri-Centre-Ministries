# Sanity CMS Configuration
# Create a project at https://www.sanity.io/ and fill in these values
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API Token (server-side only, for authenticated requests)
SANITY_API_TOKEN=

# YouTube Data API v3 Key
# Used for fetching sermon videos from YouTube
NEXT_PUBLIC_YOUTUBE_API_KEY=

# Web3Forms Contact Form Key
# Get yours at https://web3forms.com/
NEXT_PUBLIC_WEB3FORMS_KEY=
